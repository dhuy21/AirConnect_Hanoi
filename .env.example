# ============================================
# AirConnect Hanoi - Environment Configuration
# ============================================
# Copy file này thành .env rồi điền giá trị thật.
# docker-compose.yml và app code đều đọc từ .env — không hardcode ở đâu khác.

# === Database (PostgreSQL + PostGIS) ===
POSTGRES_DB=airconnect_hanoi
POSTGRES_USER=airconnect_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_PORT=5432
DATABASE_URL=postgresql://airconnect_user:change_me_in_production@localhost:5432/airconnect_hanoi

# === Backend — NestJS ===
PORT=3001
NODE_ENV=development
JWT_SECRET=change_me_in_production
JWT_EXPIRATION=7d
CORS_ORIGINS=http://localhost:3000

# === Frontend — Next.js ===
NEXT_PUBLIC_API_URL=http://localhost:3001
