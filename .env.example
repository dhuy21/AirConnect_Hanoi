# =============================================================================
# AirConnect Hanoi — Environment Variables (Example)
# =============================================================================
# Copy file này thành `.env` và điền giá trị thật cho LOCAL DEV.
# Trên Railway: cấu hình tương ứng ở Service Variables (mỗi environment).
#
# Quy ước:
#   - Biến có prefix NEXT_PUBLIC_* sẽ bị expose ra browser (Next.js).
#   - Biến còn lại chỉ dùng server-side (backend / Next.js SSR).
#   - KHÔNG commit .env thật. File này là template duy nhất, mọi biến mới
#     phải được document ở đây.
# =============================================================================

# -----------------------------------------------------------------------------
# Database — PostgreSQL 16 + PostGIS 3.4
# -----------------------------------------------------------------------------
# Local dev: docker-compose.yml dùng POSTGRES_* để tạo container.
# Railway: chỉ cần DATABASE_URL (do service Postgres của Railway inject).
POSTGRES_DB=airconnect_hanoi
POSTGRES_USER=airconnect_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_PORT=5432
DATABASE_URL=postgresql://airconnect_user:change_me_in_production@localhost:5432/airconnect_hanoi

# -----------------------------------------------------------------------------
# Redis — cache, distributed rate-limit, future queue
# -----------------------------------------------------------------------------
# Local dev: có thể dùng `docker run --rm -p 6379:6379 redis:7-alpine`.
# Railway: service Redis inject REDIS_URL tự động.
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Backend — NestJS API
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3001
# CORS: danh sách origin được phép, ngăn cách bằng dấu phẩy (không space)
CORS_ORIGINS=http://localhost:3000

# JWT — bắt buộc đổi trong production (tối thiểu 32 ký tự random)
# Gen: openssl rand -base64 48
JWT_SECRET=change_me_in_production
JWT_EXPIRATION=7d

# Rate-limit (throttler). Để trống sẽ dùng default in-module.
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Logging — dùng ở Phase 5 (pino)
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Frontend — Next.js
# -----------------------------------------------------------------------------
# URL backend được FE gọi (SSR + client).
# Production: có thể trỏ sang Next.js proxy route (/api/backend) ở Phase 5
# để ẩn backend khỏi client trực tiếp.
NEXT_PUBLIC_API_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Observability — bật ở Phase 5
# -----------------------------------------------------------------------------
# Sentry — error tracking cho cả FE & BE
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=

# Better Stack (Logtail) — structured logs ingestion
LOGTAIL_SOURCE_TOKEN=

# -----------------------------------------------------------------------------
# Seed / Admin bootstrap
# -----------------------------------------------------------------------------
# Dùng cho script `pnpm db:seed` — tài khoản admin đầu tiên.
SEED_ADMIN_EMAIL=admin@airconnect.local
SEED_ADMIN_PASSWORD=change_me_in_production

# -----------------------------------------------------------------------------
# Railway-specific (auto-inject trên Railway, không cần set local)
# -----------------------------------------------------------------------------
# RAILWAY_ENVIRONMENT=production | staging | pr-*
# RAILWAY_PROJECT_ID=...
# RAILWAY_SERVICE_ID=...
# RAILWAY_PUBLIC_DOMAIN=...
# RAILWAY_PRIVATE_DOMAIN=...
