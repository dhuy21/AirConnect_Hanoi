{
  "name": "@airconnect/shared-types",
  "version": "0.1.0",
  "private": true,
  "description": "Shared TypeScript types: enums + OpenAPI-generated API contract",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./enums": {
      "types": "./dist/enums.d.ts",
      "import": "./dist/enums.js",
      "require": "./dist/enums.cjs"
    },
    "./api": {
      "types": "./dist/api.d.ts",
      "import": "./dist/api.js",
      "require": "./dist/api.cjs"
    }
  },
  "files": ["dist", "openapi.json"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no lint config — package is mostly generated code' && exit 0",
    "codegen": "openapi-ts -i ./openapi.json -o ./src/generated -c @hey-api/client-fetch",
    "codegen:from-backend": "pnpm --filter @airconnect/backend openapi:export && pnpm run codegen && pnpm run build"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.87.5",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
