DATABASE_URL=postgresql://your_user:your_password@your_host:5432/your_database
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# Frontend variables (Vite requires VITE_ prefix)
# For local development: Leave empty or use http://localhost:8000
# For tunneling with two tunnels: Set to your backend tunnel URL (e.g., https://backend-url.trycloudflare.com)
VITE_BACKEND_URL=
VITE_FRONTEND_URL=http://localhost:5173
