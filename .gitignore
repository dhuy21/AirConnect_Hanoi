# ============================================
# Environment Variables
# ============================================
.env
.env*
!.env.example

# ============================================
# Node.js / pnpm
# ============================================
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# pnpm store
.pnpm-store/

# pnpm workspace: only the root pnpm-lock.yaml is authoritative.
# Reject stray npm/yarn lockfiles left over from pre-monorepo history.
apps/*/package-lock.json
apps/*/yarn.lock
packages/*/package-lock.json
packages/*/yarn.lock

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Testing
coverage/
*.lcov
.nyc_output

# ============================================
# Next.js
# ============================================
.next/
out/
next-env.d.ts
*.tsbuildinfo

# ============================================
# NestJS
# ============================================
dist/

# ============================================
# Turborepo
# ============================================
.turbo/

# ============================================
# Build / Production
# ============================================
build/

# ============================================
# IDE / Editor
# ============================================
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*.sw?

# ============================================
